<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">

<head>

<title>Edit Product</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body>

<div
th:replace="~{fragments/navbar :: navbar('Edit Product')}"></div>

<div class="container mt-5">

<div class="card">

<div class="card-header bg-warning">

<h3>Edit Product</h3>

</div>

<div class="card-body">

<form
th:action="@{/admin/products/{id}(id=${product.id})}"
th:object="${product}"
method="post">

<input
type="hidden"
name="_method"
value="put">

<div class="mb-3">

<label>Name</label>

<input
type="text"
th:field="*{name}"
class="form-control">

</div>

<div class="mb-3">

<label>Description</label>

<input
type="text"
th:field="*{description}"
class="form-control">

</div>

<div class="mb-3">

<label>Price</label>

<input
type="number"
step="0.01"
th:field="*{price}"
class="form-control">

</div>

<div class="mb-3">

<label>Quantity</label>

<input
type="number"
th:field="*{quantity}"
class="form-control">

</div>

<button
class="btn btn-primary">

Update Product

</button>

</form>

</div>

</div>

</div>

</body>

</html>